# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# WalletConnect Project ID (from cloud.reown.com, optional)
WC_PROJECT_ID=your_walletconnect_project_id_here

# Electrum Server (optional, defaults to mainnet-js default)
ELECTRUM_SERVER=

# Database path (optional, defaults to ./data/bot.db)
DB_PATH=

# Verification timeout settings (in minutes)
# Users are warned when this time passes without verification
PENDING_VERIFICATION_WARN_MINUTES=20
# Users are kicked when this time passes without verification
PENDING_VERIFICATION_TIMEOUT_MINUTES=30
